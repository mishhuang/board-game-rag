# LibreChat
MONGO_URI=mongodb://mongodb:27017/LibreChat
ALLOW_REGISTRATION=true

# Optional LLM providers (add keys for providers you want to use)
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# pgvector
POSTGRES_USER=pguser
POSTGRES_PASSWORD=pgpassword
POSTGRES_DB=ragdb
DATABASE_URL=postgresql://pguser:pgpassword@vectordb:5432/ragdb
DB_HOST=vectordb
DB_PORT=5432

# RAG API
RAG_API_URL=http://rag_api:8000
EMBEDDINGS_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
EMBEDDINGS_MODEL=nomic-embed-text
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# JWT (change these to random strings in production)
JWT_SECRET=change_this_to_a_random_string
JWT_REFRESH_SECRET=change_this_to_another_random_string